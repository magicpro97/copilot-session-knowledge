#!/bin/sh
# pre-commit hook — Validate .agent.md and SKILL.md files before commit
# Catches: deprecated fields, unknown tool names, schema mismatches
# Also: blocks commit when dispatched-subagent-active marker is set.
#
# Install: python3 ~/.copilot/tools/install.py --install-git-hooks
# (Do NOT hand-copy: use install.py so the canonical tools path is embedded.)

# ── Dispatched-subagent guard ──────────────────────────────────────────────
# Use the canonical installed path unconditionally.  Relative dirname-based
# resolution breaks when this file lives in a normal repo's .git/hooks/
# because dirname resolves to .git/hooks/, not ~/.copilot/tools.

# Portable Python interpreter detection.
# On Windows the Microsoft Store alias for python3 passes `command -v` but
# is not a real interpreter.  Verify with a no-op `-c ""` invocation.
# Also try `py` (Windows Python Launcher) as a last resort.
# Allow env override (e.g. for testing) then auto-detect.
if [ -z "$PYTHON_BIN" ] || ! "$PYTHON_BIN" -c "" 2>/dev/null; then
    PYTHON_BIN=""
    for _py in python3 python py; do
        if command -v "$_py" >/dev/null 2>&1 && "$_py" -c "" 2>/dev/null; then
            PYTHON_BIN="$_py"
            break
        fi
    done
fi
if [ -z "$PYTHON_BIN" ]; then
    # No working interpreter → fail-open (don't block commits).
    exit 0
fi

SUBAGENT_CHECK="$HOME/.copilot/tools/hooks/check_subagent_marker.py"
if [ -f "$SUBAGENT_CHECK" ]; then
    "$PYTHON_BIN" "$SUBAGENT_CHECK"
    if [ $? -ne 0 ]; then
        exit 1
    fi
fi
# ──────────────────────────────────────────────────────────────────────────

# ── UI inline-style regression guard ──────────────────────────────────────
CHANGED_ROUTES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^browse/routes/.*\.py$' || true)
if [ -n "$CHANGED_ROUTES" ]; then
    # Whitelist: dashboard.py's .db-chart-wrap block (uplot-coupled)
    # Anything else with <style> should fail
    VIOLATORS=""
    for f in $CHANGED_ROUTES; do
        staged_content=$(git show ":$f" 2>/dev/null) || staged_content=""
        style_count=$(printf '%s\n' "$staged_content" | grep -c '<style' || true)
        if [ "$style_count" -gt 0 ]; then
            if [ "$f" = "browse/routes/dashboard.py" ] && [ "$style_count" -eq 1 ] && printf '%s\n' "$staged_content" | grep -q '\.db-chart-wrap'; then
                :  # allowed: single <style> block containing .db-chart-wrap
            else
                VIOLATORS="$VIOLATORS $f"
            fi
        fi
    done
    if [ -n "$VIOLATORS" ]; then
        echo "✖ Pre-commit: inline <style> blocks detected in routes:$VIOLATORS"
        echo "  Move CSS to browse/static/css/app.css. This is enforced by test_no_inline_style_in_routes()."
        exit 1
    fi
fi
# ──────────────────────────────────────────────────────────────────────────

# Skill/agent lint — only meaningful in the tools repo itself; silently skips
# in other repos where lint-skills.py is absent.
TOOLS_DIR="$HOME/.copilot/tools"
HOOK_SCRIPT="$TOOLS_DIR/hooks/lint-skills.py"

# Only run if the lint script exists
if [ ! -f "$HOOK_SCRIPT" ]; then
    exit 0
fi

# Collect staged .agent.md and SKILL.md files
STAGED_SKILLS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(\.agent\.md$|SKILL\.md$)' || true)

if [ -z "$STAGED_SKILLS" ]; then
    # No skill/agent files staged — still do a full scan for awareness
    # Use --quiet to suppress output when all clean, exit 0 regardless
    "$PYTHON_BIN" "$HOOK_SCRIPT" --all --quiet 2>/dev/null
    exit 0
fi

echo "🔍 Validating skill/agent files..."

# Run full scan (covers staged files + catches cross-file issues)
"$PYTHON_BIN" "$HOOK_SCRIPT" --all --fix
LINT_EXIT=$?

if [ $LINT_EXIT -eq 1 ]; then
    echo ""
    echo "❌ Commit blocked — fix errors above before committing."
    echo "   Warnings are informational and don't block commits."
    exit 1
fi

exit 0
