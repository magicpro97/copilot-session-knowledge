{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "python3 \"$HOME/.copilot/tools/hooks/auto-briefing.py\"",
        "powershell": "python3 \"$env:USERPROFILE\\.copilot\\tools\\hooks\\auto-briefing.py\"",
        "comment": "[GLOBAL] Auto-run briefing.py at session start",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "python3 \"$HOME/.copilot/tools/hooks/session-end.py\"",
        "powershell": "python3 \"$env:USERPROFILE\\.copilot\\tools\\hooks\\session-end.py\"",
        "comment": "[GLOBAL] Cleanup markers on session end",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "python3 \"$HOME/.copilot/tools/hooks/enforce-briefing.py\"",
        "powershell": "python3 \"$env:USERPROFILE\\.copilot\\tools\\hooks\\enforce-briefing.py\"",
        "comment": "[GLOBAL] Block edit/create until briefing is done",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 \"$HOME/.copilot/tools/hooks/enforce-learn.py\"",
        "powershell": "python3 \"$env:USERPROFILE\\.copilot\\tools\\hooks\\enforce-learn.py\"",
        "comment": "[GLOBAL] Block git commit until learn.py is called after significant edits",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "python3 \"$HOME/.copilot/tools/hooks/learn-reminder.py\"",
        "powershell": "python3 \"$env:USERPROFILE\\.copilot\\tools\\hooks\\learn-reminder.py\"",
        "comment": "[GLOBAL] Remind to record learnings after task_complete",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 \"$HOME/.copilot/tools/hooks/test-after-edit.py\"",
        "powershell": "python3 \"$env:USERPROFILE\\.copilot\\tools\\hooks\\test-after-edit.py\"",
        "comment": "[GLOBAL] Remind to run tests after 3+ Python file edits",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 \"$HOME/.copilot/tools/hooks/tentacle-suggest.py\"",
        "powershell": "python3 \"$env:USERPROFILE\\.copilot\\tools\\hooks\\tentacle-suggest.py\"",
        "comment": "[GLOBAL] Suggest tentacle-orchestration when edits span 3+ files across 2+ modules",
        "timeoutSec": 5
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "python3 \"$HOME/.copilot/tools/hooks/error-search-kb.py\"",
        "powershell": "python3 \"$env:USERPROFILE\\.copilot\\tools\\hooks\\error-search-kb.py\"",
        "comment": "[GLOBAL] Auto-search knowledge base when errors occur",
        "timeoutSec": 10
      }
    ]
  }
}
