{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "/home/linhnt102/.copilot/tools/hooks/auto-briefing.sh",
        "comment": "[GLOBAL] Auto-run briefing.py at session start",
        "timeoutSec": 15
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "/home/linhnt102/.copilot/tools/hooks/enforce-briefing.sh",
        "comment": "[GLOBAL] Block edit/create until briefing is done",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "/home/linhnt102/.copilot/tools/hooks/learn-reminder.sh",
        "comment": "[GLOBAL] Remind to record learnings after task_complete",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 /home/linhnt102/.copilot/tools/hooks/references/docs-reminder.py",
        "comment": "[GLOBAL] Remind to update docs after 3+ code edits",
        "timeoutSec": 5
      }
    ]
  }
}
