{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "/Users/linhn/.copilot/tools/hooks/auto-briefing.sh",
        "comment": "[GLOBAL] Auto-run briefing.py at session start",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "/Users/linhn/.copilot/tools/hooks/session-end.sh",
        "comment": "[GLOBAL] Cleanup temp markers on session end",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "/Users/linhn/.copilot/tools/hooks/enforce-briefing.sh",
        "comment": "[GLOBAL] Block edit/create until briefing is done",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "/Users/linhn/.copilot/tools/hooks/learn-reminder.sh",
        "comment": "[GLOBAL] Remind to record learnings after task_complete",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 /Users/linhn/.copilot/tools/hooks/references/docs-reminder.py",
        "comment": "[GLOBAL] Remind to update docs after 3+ code edits",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "/Users/linhn/.copilot/tools/hooks/test-after-edit.sh",
        "comment": "[GLOBAL] Remind to run tests after 3+ Python file edits",
        "timeoutSec": 5
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "/Users/linhn/.copilot/tools/hooks/error-search-kb.sh",
        "comment": "[GLOBAL] Auto-search knowledge base when errors occur",
        "timeoutSec": 10
      }
    ]
  }
}
