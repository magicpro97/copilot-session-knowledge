{
  "_meta": {
    "version": "1.0.0",
    "description": "Auto-generated by conductor-creator. Review and customize.",
    "last_updated": "",
    "intentionally_unrouted": []
  },
  "task_types": {
    "feature": {
      "description": "New functionality or enhancement",
      "keywords": ["create", "implement", "add", "new", "feature", "build", "develop", "endpoint", "API", "screen", "component", "export", "import", "integrate"],
      "negative_keywords": ["fix", "bug", "error", "broken", "refactor"]
    },
    "bug": {
      "description": "Fix existing issues",
      "keywords": ["fix", "bug", "error", "broken", "crash", "fail", "issue", "investigate", "regression", "debug", "hotfix", "patch"],
      "negative_keywords": ["feature", "new", "create"]
    },
    "refactor": {
      "description": "Improve without changing behavior",
      "keywords": ["refactor", "rename", "simplify", "restructure", "cleanup", "optimize", "improve", "reorganize", "extract", "consolidate"],
      "negative_keywords": ["bug", "fix", "error", "new feature"]
    },
    "ops": {
      "description": "Infrastructure and deployment",
      "keywords": ["deploy", "log", "monitor", "alarm", "queue", "config", "credential", "infrastructure", "cloud", "CI", "CD", "pipeline"],
      "negative_keywords": ["code", "implement"]
    },
    "docs": {
      "description": "Documentation and diagrams",
      "keywords": ["document", "readme", "diagram", "chart", "spec", "guide", "wiki", "markdown", "write doc", "pdf", "report"],
      "negative_keywords": ["code", "implement", "fix"]
    },
    "analysis": {
      "description": "Code or architecture analysis",
      "keywords": ["analyze", "review", "audit", "assess", "investigate", "performance", "security", "architecture", "dependency"],
      "negative_keywords": ["implement", "create", "build"]
    },
    "test": {
      "description": "Test creation and maintenance",
      "keywords": ["test", "spec", "coverage", "assertion", "mock", "unit test", "e2e", "integration test", "playwright"],
      "negative_keywords": ["fix test", "broken test"]
    },
    "config": {
      "description": "Configuration changes",
      "keywords": ["config", "setting", "setup", "install", "environment", "dependency", "package", "lint", "format", "eslint", "prettier"],
      "negative_keywords": []
    }
  },
  "phrase_priority": {
    "description": "Checked BEFORE keyword scoring. Resolves common ambiguities.",
    "rules": [
      {"phrase": "review and fix", "type": "bug", "reason": "'fix' intent dominates 'review'"},
      {"phrase": "investigate and fix", "type": "bug", "reason": "'fix' is the action"},
      {"phrase": "optimize performance", "type": "refactor", "reason": "optimization = refactor, not feature"},
      {"phrase": "write test", "type": "test", "reason": "explicit test writing intent"},
      {"phrase": "add test", "type": "test", "reason": "explicit test addition intent"},
      {"phrase": "check log", "type": "ops", "reason": "log checking = ops task"},
      {"phrase": "test account", "type": "ops", "reason": "account management = ops, not test"}
    ]
  },
  "multi_module_indicators": {
    "description": "Detect cross-cutting tasks spanning multiple modules.",
    "threshold": 2,
    "zones": {}
  },
  "workflows": {
    "full-lifecycle": {
      "applies_to": ["feature"],
      "phases": ["clarify", "design", "build", "test", "review", "commit"],
      "skip_conditions": ["trivial change (<3 files)", "documentation-only"]
    },
    "lite-fix": {
      "applies_to": ["bug"],
      "phases": ["investigate", "fix", "test", "review"],
      "skip_conditions": ["typo fix", "config-only"]
    },
    "refactor-flow": {
      "applies_to": ["refactor"],
      "phases": ["analyze", "plan", "refactor", "test", "review"],
      "skip_conditions": ["rename-only"]
    },
    "ops-only": {
      "applies_to": ["ops"],
      "phases": ["execute", "verify"],
      "skip_conditions": []
    },
    "docs-only": {
      "applies_to": ["docs"],
      "phases": ["research", "write", "review"],
      "skip_conditions": ["typo fix"]
    },
    "analysis-only": {
      "applies_to": ["analysis"],
      "phases": ["gather", "analyze", "report"],
      "skip_conditions": []
    },
    "test-only": {
      "applies_to": ["test"],
      "phases": ["identify", "write", "run", "review"],
      "skip_conditions": []
    },
    "config-only": {
      "applies_to": ["config"],
      "phases": ["change", "verify"],
      "skip_conditions": []
    }
  },
  "skill_routing": {},
  "agent_routing": {},
  "model_rules": {
    "code_generation": "claude-sonnet-4.6",
    "code_review": "claude-sonnet-4.6",
    "qa_audit": "claude-opus-4.6",
    "exploration": "claude-haiku-4.5"
  },
  "mandatory_steps": {
    "pre_task": [],
    "post_code": [],
    "post_feature": [],
    "post_task": []
  }
}
