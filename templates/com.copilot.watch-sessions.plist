<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.copilot.watch-sessions</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>tools/watch-sessions.py</string>
        <string>--daemon</string>
    </array>

    <key>WorkingDirectory</key>
    <!-- CHANGE THIS to your home directory -->
    <string>/Users/YOUR_USERNAME/.copilot</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/YOUR_USERNAME/.copilot/session-state/.watch-launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USERNAME/.copilot/session-state/.watch-launchd.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
